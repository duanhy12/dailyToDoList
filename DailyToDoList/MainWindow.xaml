<Window x:Class="DailyToDoList.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DailyToDoList.Models"
        mc:Ignorable="d"
        Title="Daily To Do List"
        Width="420"
        Height="760"
        MinWidth="260"
        MinHeight="180"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="Transparent">
        <Thumb x:Name="ResizeThumb"
               Width="10"
               HorizontalAlignment="Left"
               Cursor="SizeWE"
               DragDelta="ResizeThumb_OnDragDelta" />
        <Thumb x:Name="CornerResizeThumb"
               Width="18"
               Height="18"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="6"
               Cursor="SizeNWSE"
               DragDelta="CornerResizeThumb_OnDragDelta" />

        <Border x:Name="WindowCard"
                Margin="6"
                CornerRadius="26"
                BorderBrush="#33E2E8F0"
                BorderThickness="1"
                Effect="{StaticResource PanelShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F0162235" Offset="0"/>
                    <GradientStop Color="#EE0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid x:Name="ExpandedPanel" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#14FFFFFF"
                            CornerRadius="20"
                            Padding="16"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Today’s focus"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="My Tasks"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Stay on track with a docked planner that gets out of your way."
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="46"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    CornerRadius="16"
                                    Background="{StaticResource AccentSoftBrush}">
                                <TextBlock Text="✓"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="24"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#1AFFFFFF"
                            CornerRadius="20"
                            Padding="12"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TaskInput"
                                     Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="16"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TaskInput_OnKeyDown"
                                     ToolTip="Type a task and press Enter"/>

                            <Button Grid.Column="1"
                                    Width="44"
                                    Height="44"
                                    Margin="10,0,0,0"
                                    Click="AddTaskButton_OnClick"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Background="{StaticResource AccentBrush}">
                                <TextBlock Text="+"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#14FFFFFF"
                                CornerRadius="22"
                                Padding="10">
                            <ListBox x:Name="ActiveTasksList"
                                     ItemsSource="{Binding ActiveTasks}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     AllowDrop="True"
                                     PreviewMouseLeftButtonDown="ActiveTasksList_OnPreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ActiveTasksList_OnPreviewMouseMove"
                                     Drop="ActiveTasksList_OnDrop">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TaskItem}">
                                        <Border Margin="0,0,0,10"
                                                Padding="14"
                                                Background="#1BFFFFFF"
                                                CornerRadius="18"
                                                BorderBrush="#1FFFFFFF"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                          Click="TaskCheckBox_OnClick"
                                                          Style="{StaticResource TaskCheckBoxStyle}"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Top"/>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontSize="15"
                                                         VerticalAlignment="Center"/>

                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,0">
                                                    <TextBlock Text="↕"
                                                               FontSize="16"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Button Content="✕"
                                                            Tag="{Binding}"
                                                            Click="DeleteTaskButton_OnClick"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Padding="8,4"
                                                            FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Expander Grid.Row="1"
                                  Margin="0,14,0,0"
                                  IsExpanded="{Binding ShowCompletedTasks}"
                                  Expanded="CompletedTasksExpander_OnChanged"
                                  Collapsed="CompletedTasksExpander_OnChanged"
                                  Background="#14FFFFFF"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Completed"
                                               FontWeight="SemiBold"/>
                                    <Border Background="{StaticResource AccentSoftBrush}"
                                            CornerRadius="10"
                                            Margin="8,0,0,0"
                                            Padding="8,2">
                                        <TextBlock Text="{Binding CompletedCount}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Expander.Header>
                            <Border Padding="8" Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding CompletedTasks}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         MaxHeight="240">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TaskItem}">
                                            <Border Margin="0,0,0,8"
                                                    Padding="12"
                                                    Background="#12000000"
                                                    CornerRadius="16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                              Click="TaskCheckBox_OnClick"
                                                              Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#FFCBD5E1"
                                                                   TextDecorations="Strikethrough"/>
                                                        <TextBlock Text="{Binding CompletedAt, StringFormat='Done {0:g}'}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Content="✕"
                                                            Tag="{Binding}"
                                                            Click="DeleteTaskButton_OnClick"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Padding="8,4"
                                                            FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Expander>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#12000000"
                            CornerRadius="16"
                            Padding="12"
                            Margin="0,14,0,0">
                        <TextBlock Text="Tip: drag active tasks to reorder them. Move the mouse away and the panel slides back into a compact tab."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </Border>
                </Grid>

                <Grid x:Name="CollapsedPanel" Visibility="Collapsed" Margin="10">
                    <Border Width="74"
                            Height="158"
                            Background="#F01E293B"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="#44E2E8F0"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="☰"
                                       HorizontalAlignment="Center"
                                       FontSize="22"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tasks"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="12"
                                    Padding="10,4"
                                    Margin="0,10,0,0">
                                <TextBlock Text="{Binding ActiveCount}"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
