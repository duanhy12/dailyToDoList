<Window x:Class="DailyToDoList.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DailyToDoList.Models"
        mc:Ignorable="d"
        Title="Daily To Do List"
        Width="420"
        Height="760"
        MinWidth="280"
        MinHeight="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True">
    <Grid x:Name="RootGrid" Background="Transparent">

        <Border x:Name="WindowCard"
                Margin="0,8,8,8"
                CornerRadius="18"
                BorderBrush="#40A9895A"
                BorderThickness="1"
                Effect="{StaticResource PanelShadow}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="WindowCardScaleTransform"/>
            </Border.RenderTransform>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource PaperLightColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource PaperMidColor}" Offset="0.65"/>
                    <GradientStop Color="{StaticResource PaperShadowColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid ClipToBounds="True">
                <Thumb x:Name="ResizeThumb"
                       Width="8"
                       HorizontalAlignment="Left"
                       Background="Transparent"
                       Cursor="SizeWE"
                       DragDelta="ResizeThumb_OnDragDelta"
                       Panel.ZIndex="6" />
                <Thumb x:Name="CornerResizeThumb"
                       Width="14"
                       Height="14"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="2"
                       Background="Transparent"
                       Cursor="SizeNWSE"
                       DragDelta="CornerResizeThumb_OnDragDelta"
                       Panel.ZIndex="6" />
                <Grid x:Name="ExpandedPanel" Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TO DO LIST"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"
                               FontSize="30"
                               FontFamily="Georgia"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False"
                                  Style="{StaticResource TaskCheckBoxStyle}"/>

                        <Border Grid.Column="1"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="0,0,0,1"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBox x:Name="TaskInput"
                                     Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LineTextBoxStyle}"
                                     KeyDown="TaskInput_OnKeyDown"
                                     ToolTip="Type a task and press Enter"/>
                        </Border>

                        <Button Grid.Column="2"
                                Width="42"
                                Height="42"
                                Click="AddTaskButton_OnClick"
                                Style="{StaticResource RoundIconButtonStyle}">
                            <TextBlock Text="+"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ActiveTasksList"
                                     Grid.Row="0"
                                     ItemsSource="{Binding ActiveTasks}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     AllowDrop="True"
                                     ItemContainerStyle="{StaticResource TaskListItemStyle}"
                                     PreviewMouseLeftButtonDown="ActiveTasksList_OnPreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ActiveTasksList_OnPreviewMouseMove"
                                     DragOver="ActiveTasksList_OnDragOver"
                                     GiveFeedback="ActiveTasksList_OnGiveFeedback"
                                     Drop="ActiveTasksList_OnDrop">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TaskItem}">
                                        <Border Margin="0,0,12,8"
                                                Padding="2,4,2,6"
                                                Background="Transparent">
                                            <Border.RenderTransform>
                                                <TranslateTransform />
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                             To="6"
                                                                             Duration="0:0:0.16"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="0.92"
                                                                             Duration="0:0:0.16"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                             To="0"
                                                                             Duration="0:0:0.16"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="1"
                                                                             Duration="0:0:0.16"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Row="0"
                                                          Grid.Column="0"
                                                          Margin="0,0,10,0"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                          Click="TaskCheckBox_OnClick"
                                                          Style="{StaticResource TaskCheckBoxStyle}"/>

                                                <TextBox Grid.Row="0"
                                                         Grid.Column="1"
                                                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource LineTextBoxStyle}"
                                                         TextWrapping="Wrap"
                                                         Margin="0,0,8,0"/>

                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="⋮⋮"
                                                               Margin="0,0,10,0"
                                                               FontSize="15"
                                                               Foreground="{StaticResource InkSoftBrush}"
                                                               Cursor="SizeAll"/>
                                                    <Button Content="✕"
                                                            Tag="{Binding}"
                                                            Click="DeleteTaskButton_OnClick"
                                                            Style="{StaticResource InkGhostButtonStyle}"
                                                            FontSize="12"/>
                                                </StackPanel>

                                                <Border Grid.Row="1"
                                                        Grid.Column="1"
                                                        Grid.ColumnSpan="2"
                                                        Height="1"
                                                        Margin="0,3,0,0"
                                                        Background="{StaticResource LineBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        <Border Grid.Row="1"
                                Margin="0,14,0,0"
                                Background="#18FFFFFF"
                                BorderBrush="#30A9895A"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,8">
                            <DockPanel>
                                <Expander x:Name="CompletedExpander"
                                          IsExpanded="{Binding ShowCompletedTasks}"
                                          Expanded="CompletedTasksExpander_OnChanged"
                                          Collapsed="CompletedTasksExpander_OnChanged"
                                          Background="Transparent"
                                          Foreground="{StaticResource InkBrush}"
                                          DockPanel.Dock="Left">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Completed"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource InkBrush}"/>
                                            <Border Background="#35B88355"
                                                    CornerRadius="10"
                                                    Margin="8,0,0,0"
                                                    Padding="8,2">
                                                <TextBlock Text="{Binding CompletedCount}"
                                                           Foreground="{StaticResource InkBrush}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Expander.Header>
                                    <Border Padding="4,10,0,0">
                                        <ListBox ItemsSource="{Binding CompletedTasks}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemContainerStyle="{StaticResource TaskListItemStyle}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="220">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:TaskItem}">
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  Margin="0,0,10,0"
                                                                  IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                                  Click="TaskCheckBox_OnClick"
                                                                  Style="{StaticResource TaskCheckBoxStyle}"/>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="{StaticResource InkSoftBrush}"
                                                                       TextWrapping="Wrap"
                                                                       TextDecorations="Strikethrough"/>
                                                            <TextBlock Text="{Binding CompletedAt, StringFormat='Done {0:g}'}"
                                                                       Foreground="{StaticResource InkSoftBrush}"
                                                                       FontSize="11"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2"
                                                                Content="✕"
                                                                Tag="{Binding}"
                                                                Click="DeleteTaskButton_OnClick"
                                                                Style="{StaticResource InkGhostButtonStyle}"
                                                                FontSize="12"/>

                                                        <Border Grid.Row="1"
                                                                Grid.Column="1"
                                                                Grid.ColumnSpan="2"
                                                                Height="1"
                                                                Margin="0,5,0,0"
                                                                Background="{StaticResource LineBrush}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Expander>

                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="HelpButton"
                                            Width="30"
                                            Height="30"
                                            Margin="12,0,0,0"
                                            Click="HelpButton_OnClick"
                                            Style="{StaticResource RoundIconButtonStyle}"
                                            Background="#AA9E6F47">
                                        <TextBlock Text="?"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </Grid>

                </Grid>

                <Grid x:Name="CollapsedPanel"
                      Visibility="Collapsed"
                      Background="Transparent"
                      MouseLeftButtonDown="CollapsedPanel_OnMouseLeftButtonDown"
                      MouseMove="CollapsedPanel_OnMouseMove"
                      MouseLeftButtonUp="CollapsedPanel_OnMouseLeftButtonUp">
                    <Border HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="18"
                            BorderBrush="#40A9895A"
                            BorderThickness="1"
                            Effect="{StaticResource PanelShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFF5ECCE" Offset="0"/>
                                <GradientStop Color="#FFE4D3A0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="≡"
                                       Grid.Row="0"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="20"/>

                            <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                <Border Height="1" Margin="8,4,8,0" Background="{StaticResource LineBrush}"/>
                                <Border Height="1" Margin="8,8,8,0" Background="{StaticResource LineBrush}"/>
                                <Border Height="1" Margin="8,8,8,0" Background="{StaticResource LineBrush}"/>
                            </StackPanel>

                            <Border Grid.Row="2"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Background="#35B88355"
                                    CornerRadius="12"
                                    Padding="8,3">
                                <TextBlock Text="{Binding ActiveCount}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Popup x:Name="HelpPopup"
               PlacementTarget="{Binding ElementName=HelpButton}"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="#FDF1D7"
                    BorderBrush="#C6A979"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Width="250"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="How to use"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="Bold"
                               FontSize="16"/>
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource InkBrush}"
                               TextWrapping="Wrap"
                               Text="• Type a task and press Enter or +.&#10;• Tick a box to archive it below.&#10;• Drag a task row to reorder active items.&#10;• Hover away to collapse the note.&#10;• Hover the mini note to open it again."/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="DragGhostPopup"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootGrid}"
               IsHitTestVisible="False"
               AllowsTransparency="True">
            <Border Background="#F8E9C5"
                    BorderBrush="#C6A979"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10,6"
                    Opacity="0.95"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="☰"
                               Margin="0,0,8,0"
                               Foreground="{StaticResource InkSoftBrush}"/>
                    <TextBlock x:Name="DragGhostText"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
